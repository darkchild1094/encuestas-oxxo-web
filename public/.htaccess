RewriteEngine On

# Respaldo por si getallheaders() no esta disponible
CGIPassAuth On

# No tocar archivos reales ni directorios
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Router: todo va a index.php (menos api que se maneja aparte)
# El [L] marca como último, el [PT] preserva el tipo para el siguiente handler
RewriteRule ^(?!api/).*$ index.php [QSA,L]

